<div class="news">
  {% if site.news != blank %}
    {% assign news_size = site.news | size %}
    <div
      class="table-responsive"
      {% if include.limit and page.announcements.scrollable and news_size > 3 %}
        style="max-height: 220px; overflow-y: auto; padding-right: 0.5rem"
      {% endif %}
    >
      <table class="table table-borderless mb-0">
        {% assign news = site.news | reverse %}
        {% if include.limit and page.announcements.limit %}
          {% assign news_limit = page.announcements.limit %}
        {% else %}
          {% assign news_limit = news_size %}
        {% endif %}
        {% for item in news limit: news_limit %}
          <tr style="vertical-align: top">
            <th scope="row" style="width: 22%; padding-bottom: 0.6rem; padding-right: 1rem; white-space: nowrap">
              {{ item.date | date: '%b %d, %Y' }}
            </th>
            <td style="padding-bottom: 0.6rem">
              {% if item.inline %}
                {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
              {% else %}
                <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
